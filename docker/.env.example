# Copy to .env and fill in. Used by docker-compose.yml for both runners.

# --- Your GitHub repos ---
RUNNER_URL=https://github.com/<you>/Scout
ATLAS_REPO=git@github.com-atlas:<you>/Atlas.git

# --- Runner-registration tokens ---
# Mint each from:
#   https://github.com/<you>/Scout/settings/actions/runners/new
# or with the CLI:
#   gh api -X POST repos/<you>/Scout/actions/runners/registration-token --jq .token
#
# IMPORTANT: registration tokens are SINGLE-USE and expire in ~1 hour. Each
# runner needs its OWN fresh token — you cannot share one across both. They are
# only consumed on a runner's FIRST boot (config.sh); once registered, the
# `.runner` file on that runner's config volume persists and the token is ignored.

# Main runner (nas-scout, label: scout) — the long research jobs.
RUNNER_TOKEN=

# Light runner (nas-scout-light, label: scout-light) — the short sharpen jobs.
RUNNER_TOKEN_LIGHT=

# --- Optional ---
# Host path to the Scout profile mounted read-only into both runners.
# Defaults to ../profile.yml (relative to docker/) when unset.
#SCOUT_PROFILE_HOST=../profile.yml
